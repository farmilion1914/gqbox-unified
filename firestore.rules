rules_version = '2';

// ============================================================
//  БАЗА УПАКОВЩИЦ (packing23-11afd)
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== СОТРУДНИКИ (employees) =====
    // Чтение — любой авторизованный; запись роли/ставки — только админ.
    match /employees/{userId} {
      allow read: if request.auth != null;
      // Запрет самостоятельной смены роли/ставки/блокировки.
      // Админ может менять всё, кроме собственного повышения до superadmin
      // (защита от само-эскалации — меняем только через доверенные поля).
      allow write: if isAdmin() && !isSelfRoleEscalation(userId);
    }

    // ===== ЗАПИСИ УПАКОВКИ (pack_records) =====
    match /pack_records/{id} {
      allow read: if request.auth != null;
      // Создавать/менять может только автор записи (userId == свой uid-подобие)
      // или админ. Упрощённо: любой авторизованный сотрудник пишет свои записи.
      allow create, update: if request.auth != null
                          && request.resource.data.userId == request.auth.token.email
                          || isAdmin();
      allow delete: if isAdmin();
    }

    // ===== ПОСЕЩАЕМОСТЬ (attendance) =====
    match /attendance/{id} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                              && request.resource.data.userId == request.auth.token.email
                              || isAdmin();
      allow delete: if isAdmin();
    }

    // ===== ФОТО ТОВАРОВ (product_photos) =====
    match /product_photos/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ===== ПРОЧИЕ (логи и т.п.) =====
    match /{document=**} {
      allow read: if request.auth != null && isAdmin();
      allow write: if isAdmin();
    }

    // ===== ФУНКЦИИ-ПОМОЩНИКИ =====
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/employees/$(request.auth.uid))
        && (get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    // Запрет само-эскалации: нельзя менять свою роль/ставку/блокировку
    function isSelfRoleEscalation(targetUserId) {
      return targetUserId == request.auth.uid
        && ('role' in request.resource.data
            || 'warehouseRole' in request.resource.data
            || 'active' in request.resource.data
            || 'dailyRate' in request.resource.data);
    }
  }
}